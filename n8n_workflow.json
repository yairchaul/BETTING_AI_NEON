# ============================================
# SIDEBAR - CONTROLES
# ============================================
with st.sidebar:
    st.header("🎯 CONTROLES")
    
    if st.button("🔄 ACTUALIZAR PARTIDOS", use_container_width=True):
        with st.spinner("Extrayendo partidos..."):
            st.session_state.partidos_futbol = st.session_state.odds_api.get_partidos_futbol()
            st.session_state.partidos_nba = st.session_state.odds_api.get_partidos_nba()
            
            todos_picks = []
            
            # Procesar fútbol
            for p in st.session_state.partidos_futbol:
                try:
                    probs = st.session_state.predictor.predecir_partido_futbol(p)
                    # Aquí iría rule engine (simplificado)
                    for nivel in range(1, 7):
                        pick = {
                            'deporte': '⚽',
                            'liga': p['liga'],
                            'partido': f"{p['local']} vs {p['visitante']}",
                            'local': p['local'],
                            'visitante': p['visitante'],
                            'desc': f"Over 1.5 ({p['local']} vs {p['visitante']})",
                            'prob': probs.get('over_1_5', 0.7),
                            'cuota': round(1/probs.get('over_1_5', 0.7) * 0.95, 2),
                            'value': 0.05,
                            'nivel': nivel,
                            'gf_local': probs.get('local', {}).get('gf', 0),
                            'gf_visit': probs.get('visitante', {}).get('gf', 0)
                        }
                        todos_picks.append(pick)
                except:
                    pass
            
            st.session_state.todos_picks = todos_picks
            st.success(f"✅ {len(todos_picks)} picks generados")
    
    if st.button("🤖 DEBATIR PICKS", use_container_width=True):
        with st.spinner("Agentes debatiendo..."):
            resultados = st.session_state.debate.obtener_top_consenso(
                st.session_state.todos_picks, top_n=10
            )
            st.session_state.debate_resultados = resultados
            st.success("✅ Debate completado")
    
    if st.button("🔌 PROBAR MCP", use_container_width=True):
        if st.session_state.mcp.mcp_available:
            st.success("✅ MCP disponible")
        else:
            st.warning("⚠️ MCP no instalado. Ejecuta: pip install mcp-odds-api")
    
    st.markdown("---")
    st.markdown("""
    ### 📋 INSTRUCCIONES
    1. **Actualizar** partidos
    2. **Debatir** picks con IA
    3. **Agregar** al parlay
    4. **Registrar** resultados
    """)

